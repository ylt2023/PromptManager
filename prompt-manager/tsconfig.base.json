{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "paths": {
      "@prompt-mgr/core": ["./packages/core/src"],
      "@prompt-mgr/core/*": ["./packages/core/src/*"],
      "@prompt-mgr/ui": ["./packages/ui/src"],
      "@prompt-mgr/ui/*": ["./packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
