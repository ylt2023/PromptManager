{
  "$schema": "https://raw.githubusercontent.com/niconia/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "PromptManager",
  "version": "0.1.0",
  "identifier": "com.promptmgr.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PromptManager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:prompt-manager.db"]
    }
  }
}
